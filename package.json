{
  "name": "screenshot-color-picker",
  "version": "1.0.0",
  "description": "Extract text, bounding boxes, and colors from screenshots",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "npm --prefix client start",
    "build": "npm --prefix client run build",
    "install-all": "npm install && npm --prefix server install && npm --prefix client install"
  },
  "keywords": [
    "ocr",
    "color-extraction",
    "screenshot",
    "image-processing"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "opencv.js": "^1.2.1",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "vercel": "^54.10.2"
  }
}
