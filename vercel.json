{
  "version": 2,
  "buildCommand": "npm --prefix client run build",
  "outputDirectory": "client/build",
  "installCommand": "npm --prefix client install",
  "framework": "react",
  "env": {
    "REACT_APP_API_URL": "@react-app-api-url"
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}