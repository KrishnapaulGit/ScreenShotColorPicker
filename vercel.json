{
  "version": 2,
  "buildCommand": "npm install && npm --prefix client install && npm --prefix client run build",
  "outputDirectory": "client/build",
  "devCommand": "node server/api/index.js",
  "functions": {
    "server/api/index.js": {
      "maxDuration": 60,
      "memory": 3008
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/api/index.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/manifest.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}